my $progname = 'llama-pack';

my $def_port = 8080;
my $def_host = '127.0.0.1';
my $config_dir = $ENV{HOME} . "/.config/$progname";
my $config_file = "$config_dir/config.json";
my $editor = $ENV{EDITOR} // 'vim';

# ANSI color exports
our ($bgbla, $bgred, $bggre, $bgbro, $bgblu, $bgmag, $bgcya, $bggra);
our ($bla, $red, $gre, $bro, $blu, $mag, $cya, $gra);
our ($bbla, $bred, $bgre, $yel, $bblu, $bmag, $bcya, $whi);
our ($rst, $inv, $cll, $cllr, $cls, $clsb, $ahome);
our ($c_warn, $c_err, $c_attn, $c_attn_ctx, $c_sel, $c_tag);

init_colors();

our $verbose = $ENV{LLAMA_SERVE_VERBOSE} // 0;
our $stats_dirty = 0;
our $current_runtime_start;
our $stats;  # Global stats hash - loaded once, modified in memory, written on exit

use v5.36; # nice
sub se; sub sel; sub pe; sub pel; sub serr; sub swarn; # Keep for use w/o ()
sub pe { print STDERR @_; }
sub pel { my $l=shift; print STDERR @_ if $verbose >= $l; }
sub se { say STDERR @_; }
sub sel { my $l=shift; say STDERR @_ if $verbose >= $l; }

END {
    write_stats() if $stats_dirty;
}

$SIG{INT} = $SIG{TERM} = sub {
    update_current_runtime() if $current_runtime_start;
    $stats_dirty = 1;
    exit 0;
};

main();

sub main {
    # Parse our args vs llama-server args
    my ($opts, $llama_args) = parse_args();

    # Handle commands that don't need config loaded
    if ($opts->{edit_config}) { edit_config(); exit }

    my $config = load_config();
    # Apply config defaults if not specified on command line
    $opts->{port} //= $config->{default_port} // $def_port;
    $opts->{host} //= $config->{default_host} // $def_host;

    # Add host/port to llama_args if they weren't already added
    my $has_port = grep { $_ eq '--port' } @$llama_args;
    my $has_host = grep { $_ eq '--host' } @$llama_args;

    push @$llama_args, '--port', $opts->{port} unless $has_port;
    push @$llama_args, '--host', $opts->{host} unless $has_host;

    # Handle commands that don't need model loading
    if ($opts->{list}) {
        list_models($config);
        exit 0;
    }

    if ($opts->{status}) {
        show_status($config);
        exit 0;
    }

    if ($opts->{taglist}) {
        list_known_tags($config);
        exit 0;
    }

    if ($opts->{list_mmproj}) {
        list_mmproj($config);
        exit 0;
    }

    if ($opts->{update}) {
        scan_models($config);
        say "${gre}Model index updated.$rst";
        exit 0;
    }

    if ($opts->{simulate}) {
        run_simulation($config, $opts);
        exit 0;
    }

    # If -k without model, just kill
    if ($opts->{kill} && !$opts->{model} && !$opts->{manage_model}) {
        kill_instances($config, $opts);
        exit 0;
    }

    # If -k WITH model, kill first then continue to load model
    if ($opts->{kill} && ($opts->{model} || $opts->{manage_model})) {
        say "${c_warn}Killing existing server(s) before loading model...$rst" if $verbose;
        kill_instances($config, $opts);
    }

    # Load stats ONCE into global
    $stats = load_stats($config);

    # Handle global tag operations (must happen before model tag operations)
    if ($opts->{gtag_ops} && @{$opts->{gtag_ops}}) {
        for my $op (@{$opts->{gtag_ops}}) {
            manage_global_tag($config, $op);
        }
    }

    if ($opts->{tag_rename}) {
        rename_global_tag($config, $stats, $opts->{tag_rename});
    }

    if ($opts->{tag_desc}) {
        update_tag_description($config, $opts->{tag_desc});
    }

    # Determine which model to work with
    my $target_model = $opts->{manage_model} || $opts->{model};

    if ($verbose >= 2) {
        say "${gre}DEBUG: target_model=$target_model$rst" if $target_model;
        say "${gre}DEBUG: mmproj=$$opts{mmproj}$rst" if $opts->{mmproj};
        say "${gre}DEBUG: rm_mmproj=$$opts{rm_mmproj}$rst" if $opts->{rm_mmproj};
        say "${gre}DEBUG: manage_model=$$opts{manage_model}$rst" if $opts->{manage_model};
    }

    # If -M without other operations, show model details
    if ($opts->{manage_model} && !$opts->{model} &&
        !$opts->{tags} && !$opts->{note_edit} && !$opts->{note_str} && !$opts->{note_del} &&
        !$opts->{mmproj} && !$opts->{rm_mmproj}) {
        show_model_details($config, $stats, $opts->{manage_model});
        exit 0;
    }

    # Handle tag operations on specific model
    if ($target_model && $opts->{tags}) {
        my $model_info = find_model($config, $stats, $target_model);
        if (!$model_info) {
            serr(0, "Model '$target_model' not found.");
            exit 1;
        }
        my $model_key = basename($model_info->{path});

        my $known_tags = get_known_tags($config);
        for my $tag_op (@{$opts->{tags}}) {
            if ($tag_op =~ /^-(.+)$/) {
                # Remove tag
                remove_model_tag($stats, $model_key, $1);
            } else {
                # Add tag
                add_model_tag($stats, $model_key, $tag_op, $known_tags);
            }
        }

        # If only managing (not loading), exit now
        if ($opts->{manage_model} && !$opts->{model}) {
            exit 0;
        }
    }

    # Handle note operations on specific model
    if ($target_model && ($opts->{note_edit} || $opts->{note_str} || $opts->{note_del})) {
        my $model_info = find_model($config, $stats, $target_model);
        if (!$model_info) {
            serr(0, "Model '$target_model' not found.");
            exit 1;
        }
        my $model_key = basename($model_info->{path});

        if ($opts->{note_del}) {
            delete_model_note($stats, $model_key);
        } elsif ($opts->{note_str}) {
            set_model_note($stats, $model_key, $opts->{note_str});
        } elsif ($opts->{note_edit}) {
            edit_model_note($stats, $model_key, $editor);
        }

        # If only managing (not loading), exit now
        if ($opts->{manage_model} && !$opts->{model}) {
            exit 0;
        }
    }

    # Handle mmproj operations on specific model
    if ($target_model && ($opts->{mmproj} || $opts->{rm_mmproj})) {
        say "${gre}DEBUG: Handling mmproj for $target_model$rst" if $verbose >= 2;
        my $model_info = find_model($config, $stats, $target_model);
        if (!$model_info) {
            say STDERR "Error: Model '$target_model' not found.";
            exit 1;
        }
        my $model_key = basename($model_info->{path});
        say "${gre}DEBUG: Found model_key: $model_key$rst" if $verbose >= 2;

        if ($opts->{rm_mmproj}) {
            if (exists $stats->{$model_key}{mmproj}) {
                delete $stats->{$model_key}{mmproj};
                $stats_dirty = 1;
                say "Removed mmproj association from $model_key";
            } else {
                say "No mmproj associated with $model_key";
            }
        } elsif ($opts->{mmproj}) {
            # Just store the name, we'll find the path at load time
            $stats->{$model_key}{mmproj} = $opts->{mmproj};
            $stats_dirty = 1;
            say "Associated mmproj '$$opts{mmproj}' with $model_key";
        }

        # If only managing (not loading), exit now
        if ($opts->{manage_model} && !$opts->{model}) {
            exit 0;
        }
    }

    # Need a model to proceed with loading
    unless ($opts->{model}) {
        serr(0, "No model specified. Use -m or --model");
        exit 1;
    }

    # Auto-scan on first run if no stats file exists
    if (!-f $config->{stats_file}) {
        say "${yel}First run detected. Scanning for models...$rst";
        scan_models($config);
        $stats = load_stats($config);
    }

    # Load stats ONCE into global
    swarn 0, "Removed load_stats() from the every-run approach. Need to make sure that was okay.";
	# We might need to uncomment this, but it's likely claude made this properly only load
	# stats in paths that need it.
    # $stats = load_stats($config);

    # Find the model (future: check nicknames first)
    my $model_info = find_model($config, $stats, $opts->{model});
    unless ($model_info) {
        serr(0, "Model '$$opts{model}' not found.");
        exit 1;
    }

    say "${gre}Found model: $$model_info{path}$rst" if $verbose;

    # Handle model-specific args
    my $model_key = basename($model_info->{path});
    $stats->{$model_key} //= {};
    my $mstats = $stats->{$model_key};

    # Determine which args to use
    my @final_llama_args;
    if (@$llama_args && (!$mstats->{llama_args} || $opts->{store})) {
        # First run with args, or explicit --store: save them
        $mstats->{llama_args} = $llama_args;
        @final_llama_args = @$llama_args;
        $stats_dirty = 1;
        say "${gre}Stored model-specific args.$rst" if $verbose;
    } elsif ($mstats->{llama_args}) {
        # Use stored args
        @final_llama_args = @{$mstats->{llama_args}};
        say "${gre}Using stored model-specific args.$rst" if $verbose;
        if (@$llama_args && !$opts->{store}) {
            say "${yel}Note: New args provided but not stored. Use --store to update.$rst";
        }
    } else {
        # No stored args, use what was provided (if any)
        @final_llama_args = @$llama_args;
    }

    # Prepend global args from config
    my @global_args = @{$config->{global_llama_args} // []};
    unshift @final_llama_args, @global_args;

    # Handle mmproj if associated with model and not disabled
    if (!$opts->{no_mmproj} && $mstats->{mmproj}) {
        my $mmproj_path = find_mmproj($config, $mstats->{mmproj});
        if ($mmproj_path) {
            say "${gre}Found mmproj: $mmproj_path$rst" if $verbose;
            unshift @final_llama_args, '--mmproj', $mmproj_path;
        } else {
            say "${c_warn}mmproj '$$mstats{mmproj}' not found, skipping$rst";
        }
    }

    # Check if already running with same args
    my $pid_file = get_pid_file($config, $opts->{port});
    if (-f $pid_file) {
        my $running = read_pid_file($pid_file);
        if ($running && process_exists($running->{pid})) {
            my $args_hash = md5_hex(join('|', @final_llama_args));
            if ($running->{model} eq $model_info->{path} &&
                $running->{args_hash} eq $args_hash) {
                say "${gre}Model already running on host:port $$opts{host}:$$opts{port} with same args.$rst";
                exit 0;
            } else {
                say "${yel}Killing existing server to reload with different model/args...$rst";
                kill_pid($running->{pid});
                unlink $pid_file;
            }
        }
    }

    # Update stats for this model
    $mstats->{path} = $model_info->{path};
    $mstats->{total_uses} //= 0;
    $mstats->{total_uses}++;
    $mstats->{last_used} = gmtime->datetime;
    $mstats->{use_timestamps} //= [];
    push @{$mstats->{use_timestamps}}, gmtime->datetime;

    # Keep only last 100 timestamps to prevent bloat
    if (@{$mstats->{use_timestamps}} > 100) {
        $mstats->{use_timestamps} = [
            @{$mstats->{use_timestamps}}[-100..-1]
        ];
    }

    $stats_dirty = 1;

    # Should we cache to SSD?
    if ($model_info->{location} eq 'hdd' && should_cache_to_ssd($mstats)) {
        say "${yel}Model used multiple times recently. Caching to SSD...$rst";
        fork_ssd_copy($config, $model_info, $stats);
    }

    # Start llama-server
    start_server($config, $opts, $model_info, \@final_llama_args);
}

