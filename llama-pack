sub serr {
    my ($level, @msg) = @_;
    return if $verbose < $level;
    say STDERR a24bg(100, 0, 0) . $whi, @msg, $rst;
}

sub swarn {
    my ($level, @msg) = @_;
    return if $verbose < $level;
    say STDERR $rst, a24bg(255, 255, 90) . $bla, @msg, $rst;
}

sub init_colors {
    if (-t STDOUT) {
        ($bgbla, $bgred, $bggre, $bgbro, $bgblu, $bgmag, $bgcya, $bggra) =
            map { "\e[${_}m" } (40..47);
        ($bla, $red, $gre, $bro, $blu, $mag, $cya, $gra) =
            map { "\e[${_}m" } (30..37);
        ($bbla, $bred, $bgre, $yel, $bblu, $bmag, $bcya, $whi) =
            map { "\e[${_}m" } (90..97);
        $rst = "\e[0m";
        $inv = "\e[7m";

        # Additional color variables
        $c_warn = $yel;
        $c_err = $bred;
        $c_attn = $bcya;
        $c_attn_ctx = $cya;
        $c_sel = $bmag;
        $c_tag = $gra;
    } else {
        ($bgbla, $bgred, $bggre, $bgbro, $bgblu, $bgmag, $bgcya, $bggra) = ('') x 8;
        ($bla, $red, $gre, $bro, $blu, $mag, $cya, $gra) = ('') x 8;
        ($bbla, $bred, $bgre, $yel, $bblu, $bmag, $bcya, $whi) = ('') x 8;
        $rst = $inv = '';

        # Additional color variables
        $c_warn = $c_err = $c_attn = $c_attn_ctx = $c_sel = $c_tag = '';
    }
}

sub a24bg {
    my ($r, $g, $b) = @_;
    return '' unless -t STDOUT;
    return "\e[48;2;${r};${g};${b}m";
}

sub a24fg {
    my ($r, $g, $b) = @_;
    return '' unless -t STDOUT;
    return "\e[38;2;${r};${g};${b}m";
}
