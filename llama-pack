sub add_model_tag {
    my ($stats, $model_key, $tag, $known_tags) = @_;

    # Normalize tag
    $tag = uc($tag);
    $tag =~ s/^\s+|\s+$//g;

    # Validate tag name
    if ($tag =~ /[\s,]/) {
        say "${c_err}Invalid tag name '$tag' (no spaces or commas allowed)$rst";
        return;
    }

    # Check if known
    if (!exists $known_tags->{$tag}) {
        my @suggestions = suggest_similar_tags($tag, $known_tags);
        say "${c_warn}$tag is not a known tag.$rst";
        if (@suggestions) {
            say "  Did you mean: " . join(', ', map { "${c_attn}$_$rst" } @suggestions) . "?";
        }
        say "  Use ${c_attn}--gtag $tag:\"Description\"$rst to add $tag as a new tag first.";
        exit 1;
    }

    # Initialize tags array if needed
    $stats->{$model_key}{tags} ||= [];

    # Add if not already present
    my $tags = $stats->{$model_key}{tags};
    if (!grep { $_ eq $tag } @$tags) {
        push @$tags, $tag;
        @$tags = sort @$tags;  # Keep sorted
        $stats_dirty = 1;
        say "${c_attn}Added tag $tag to $model_key$rst" if $verbose;
    } else {
        say "${c_warn}Tag $tag already present on $model_key$rst" if $verbose;
    }
}

sub remove_model_tag {
    my ($stats, $model_key, $tag) = @_;

    # Normalize tag
    $tag = uc($tag);
    $tag =~ s/^\s+|\s+$//g;

    my $tags = $stats->{$model_key}{tags} || [];
    my $before_count = scalar @$tags;

    @$tags = grep { $_ ne $tag } @$tags;
    $stats->{$model_key}{tags} = $tags;

    if (scalar @$tags < $before_count) {
        $stats_dirty = 1;
        say "${c_attn}Removed tag $tag from $model_key$rst" if $verbose;
    } else {
        say "${c_warn}Tag $tag was not present on $model_key$rst" if $verbose;
    }
}

sub manage_global_tag {
    my ($config, $op) = @_;

    if ($op =~ /^-(.+)$/) {
        # Remove tag
        my $tag = uc($1);
        if (exists $config->{known_tags}{$tag}) {
            delete $config->{known_tags}{$tag};
            save_config($config);
            say "${c_attn}Removed $tag from global tag registry$rst";
        } else {
            say "${c_warn}Tag $tag not in registry$rst";
        }
    } elsif ($op =~ /^([^:]+):(.+)$/) {
        # Add/update tag with description
        my ($tag, $desc) = (uc($1), $2);
        $tag =~ s/^\s+|\s+$//g;
        $desc =~ s/^\s+|\s+$//g;

        if ($tag =~ /[\s,]/) {
            say "${c_err}Invalid tag name '$tag' (no spaces or commas allowed)$rst";
            return;
        }

        $config->{known_tags}{$tag} = $desc;
        save_config($config);
        say "${c_attn}Added/updated tag $tag: $desc$rst";
    } else {
        say "${c_err}Invalid --gtag format. Use: TAG:DESCRIPTION or -TAG$rst";
        exit 1;
    }
}

sub rename_global_tag {
    my ($config, $stats, $rename_spec) = @_;

    unless ($rename_spec =~ /^([^:]+):([^:]+)$/) {
        say "${c_err}Invalid rename format. Use: OLD:NEW$rst";
        exit 1;
    }

    my ($old_tag, $new_tag) = (uc($1), uc($2));
    $old_tag =~ s/^\s+|\s+$//g;
    $new_tag =~ s/^\s+|\s+$//g;

    if (!exists $config->{known_tags}{$old_tag}) {
        say "${c_err}Tag $old_tag not found in registry$rst";
        exit 1;
    }

    # Update registry
    $config->{known_tags}{$new_tag} = $config->{known_tags}{$old_tag};
    delete $config->{known_tags}{$old_tag};
    save_config($config);

    # Update all models
    my $count = 0;
    for my $model_key (keys %$stats) {
        my $tags = $stats->{$model_key}{tags} || [];
        for my $i (0 .. $#$tags) {
            if ($tags->[$i] eq $old_tag) {
                $tags->[$i] = $new_tag;
                $count++;
            }
        }
        @$tags = sort @$tags if @$tags;
    }

    $stats_dirty = 1 if $count > 0;
    say "${c_attn}Renamed $old_tag → $new_tag across $count model(s)$rst";
}

sub update_tag_description {
    my ($config, $desc_spec) = @_;

    unless ($desc_spec =~ /^([^:]+):(.+)$/) {
        say "${c_err}Invalid format. Use: TAG:DESCRIPTION$rst";
        exit 1;
    }

    my ($tag, $desc) = (uc($1), $2);
    $tag =~ s/^\s+|\s+$//g;
    $desc =~ s/^\s+|\s+$//g;

    if (!exists $config->{known_tags}{$tag}) {
        say "${c_err}Tag $tag not found in registry$rst";
        exit 1;
    }

    $config->{known_tags}{$tag} = $desc;
    save_config($config);
    say "${c_attn}Updated description for $tag: $desc$rst";
}

sub list_known_tags {
    my $config = shift;

    my $known_tags = get_known_tags($config);

    unless (keys %$known_tags) {
        say "${c_warn}No tags in global registry$rst";
        return;
    }

    say "${whi}${inv} Known Tags $rst\n";

    my $tb = Text::Table->new(
        { title => "Tag", align => 'left' },
        \"  ",
        { title => "Description", align => 'left' },
    );

    for my $tag (sort keys %$known_tags) {
        $tb->add("${c_tag}$tag$rst", $known_tags->{$tag});
    }

    print $tb;
}

sub suggest_similar_tags {
    my ($tag, $known_tags) = @_;

    my @suggestions;
    for my $known (keys %$known_tags) {
        my $dist = levenshtein($tag, $known);
        push @suggestions, { tag => $known, dist => $dist } if $dist <= 2;
    }

    @suggestions = sort { $a->{dist} <=> $b->{dist} } @suggestions;
    return map { $_->{tag} } @suggestions;
}

sub levenshtein {
    my ($s1, $s2) = @_;
    my @s1 = split //, $s1;
    my @s2 = split //, $s2;

    my @d;
    $d[$_][0] = $_ for (0 .. @s1);
    $d[0][$_] = $_ for (0 .. @s2);

    for my $i (1 .. @s1) {
        for my $j (1 .. @s2) {
            $d[$i][$j] = $s1[$i-1] eq $s2[$j-1] ? $d[$i-1][$j-1] :
                         1 + (
                             $d[$i-1][$j] < $d[$i][$j-1] ?
                             ($d[$i-1][$j] < $d[$i-1][$j-1] ? $d[$i-1][$j] : $d[$i-1][$j-1]) :
                             ($d[$i][$j-1] < $d[$i-1][$j-1] ? $d[$i][$j-1] : $d[$i-1][$j-1])
                         );
        }
    }

    return $d[@s1][@s2];
}

sub edit_model_note {
    my ($stats, $model_key, $editor) = @_;

    my $note = $stats->{$model_key}{note} || '';

    # Create temp file
    my $tmpfname = "/tmp/llama-pack-note-$$.tmp";

    my $omask = umask 0177;
    write_text($tmpfname, $note);
    umask $omask;

    # Edit
    system($editor, $tmpfname);

    # Read back
    my $newnote = read_text($tmpfname);
    $newnote =~ s/(\A\s+)|(\s+\z)//sg;
    $note =~ s/(\A\s+)|(\s+\z)//sg;

    unlink $tmpfname;

    if ($newnote eq $note) {
        say "${c_warn}No changes made$rst";
    } elsif ($newnote =~ /\A\s*\z/s) {
        delete $stats->{$model_key}{note};
        $stats_dirty = 1;
        say "${c_attn}Note deleted$rst";
    } else {
        $stats->{$model_key}{note} = $newnote;
        $stats_dirty = 1;
        say "${c_attn}Note updated$rst";
    }
}

sub set_model_note {
    my ($stats, $model_key, $note_str) = @_;

    $note_str =~ s/(\A\s+)|(\s+\z)//sg;

    if ($note_str =~ /\A\s*\z/s) {
        delete $stats->{$model_key}{note};
        say "${c_warn}Empty note, deleted$rst";
    } else {
        $stats->{$model_key}{note} = $note_str;
        say "${c_attn}Note set$rst";
    }

    $stats_dirty = 1;
}

sub delete_model_note {
    my ($stats, $model_key) = @_;

    if (exists $stats->{$model_key}{note}) {
        delete $stats->{$model_key}{note};
        $stats_dirty = 1;
        say "${c_attn}Note deleted$rst";
    } else {
        say "${c_warn}No note to delete$rst";
    }
}

sub show_model_details {
    my ($config, $stats, $model_name) = @_;

    my $model_info = find_model($config, $stats, $model_name);
    unless ($model_info) {
        serr(0, "Model '$model_name' not found.");
        exit 1;
    }

    my $model_key = basename($model_info->{path});
    my $mstats = $stats->{$model_key} || {};

    say "${whi}${inv} Model Details $rst\n";

    say "${c_attn}Name:$rst $cya$model_key$rst";
    say "${c_attn}Path:$rst $$mstats{path}" if $mstats->{path};

    if ($mstats->{size_bytes}) {
        say "${c_attn}Size:$rst " . format_size($mstats->{size_bytes});
    }

    my $locs = $model_info->{locations} || [];
    if (@$locs) {
        say "${c_attn}Locations:$rst " . join(', ', @$locs);
    }

    my $tags = $mstats->{tags} || [];
    if (@$tags) {
        say "${c_attn}Tags:$rst ${c_tag}" . join(', ', @$tags) . $rst;
    }

    if ($mstats->{mmproj}) {
        my $mmproj_path = find_mmproj($config, $mstats->{mmproj});
        if ($mmproj_path) {
            say "${c_attn}MMPROJ:$rst $$mstats{mmproj} (found: $mmproj_path)";
        } else {
            say "${c_attn}MMPROJ:$rst $$mstats{mmproj} ${c_warn}(not found)$rst";
        }
    }

    if ($mstats->{last_used}) {
        say "${c_attn}Last Used:$rst $$mstats{last_used}";
    }

    if ($mstats->{total_uses}) {
        say "${c_attn}Total Uses:$rst $$mstats{total_uses}";
    }

    if ($mstats->{total_runtime_seconds}) {
        say "${c_attn}Total Runtime:$rst " . format_time($mstats->{total_runtime_seconds});
    }

    if ($mstats->{last_runtime_seconds}) {
        say "${c_attn}Last Runtime:$rst " . format_time($mstats->{last_runtime_seconds});
    }

    # Calculate mtime range for ranking
    my ($newest_mtime, $oldest_mtime) = (0, time);
    for my $model (keys %$stats) {
        my $mtime = $stats->{$model}{mtime} || 0;
        $newest_mtime = $mtime if $mtime > $newest_mtime;
        $oldest_mtime = $mtime if $mtime < $oldest_mtime && $mtime > 0;
    }

    my $rank = rank_model($mstats, $newest_mtime, $oldest_mtime);
    say "${c_attn}Rank:$rst " . sprintf("%.1f", $rank);

    if ($mstats->{mtime}) {
        my $mtime_obj = gmtime($mstats->{mtime});
        say "${c_attn}File Modified:$rst " . $mtime_obj->strftime('%Y-%m-%d %H:%M:%S');
    }

    if ($mstats->{note}) {
        say "\n${c_attn}Notes:$rst";
        my $note = $mstats->{note};
        $note =~ s/^/  /mg;  # Indent
        say $note;
    }
}

sub find_mmproj {
    my ($config, $mmproj_name) = @_;

    # Try SSD first, then HDD
    for my $location (qw(ssd hdd)) {
        my $path = $config->{"${location}_path"};
        next unless -d $path;

        # Try exact filename match
        my $full_path = "$path/$mmproj_name";
        return $full_path if -f $full_path;

        # Try pattern match
        opendir my $dh, $path or next;
        my @matches = grep { /\Q$mmproj_name\E/i && /mmproj/i && /\.gguf$/i } readdir($dh);
        closedir $dh;

        if (@matches) {
            return "$path/$matches[0]";
        }
    }

    return undef;
}

sub list_mmproj {
    my $config = shift;

    my @mmproj_files;

    for my $location (qw(ssd hdd)) {
        my $path = $config->{"${location}_path"};
        next unless -d $path;

        opendir my $dh, $path or next;
        my @files = grep { /mmproj/i && /\.gguf$/i && -f "$path/$_" } readdir($dh);
        closedir $dh;

        for my $file (@files) {
            push @mmproj_files, {
                name => $file,
                location => $location,
                path => "$path/$file",
                size => -s "$path/$file",
            };
        }
    }

    unless (@mmproj_files) {
        say "${c_warn}No mmproj files found$rst";
        return;
    }

    say "${whi}${inv} MMPROJ Files $rst\n";

    my $tb = Text::Table->new(
        { title => "File", align => 'left' },
        \"  ",
        { title => "Location", align => 'left' },
        \"  ",
        { title => "Size", align => 'right' },
    );

    for my $file (sort { $a->{name} cmp $b->{name} } @mmproj_files) {
        my $loc_str = $file->{location} eq 'ssd' ? "${bcya}SSD${rst}" : "${yel}HDD${rst}";
        my $size_str = format_size($file->{size});
        $tb->add("${cya}$$file{name}${rst}", $loc_str, $size_str);
    }

    print $tb;
    say "\n${gra}Total: " . scalar(@mmproj_files) . " file(s)$rst";
}

sub list_models {
    my $config = shift;

    # Get terminal width
    my $term_width = eval {
        require Term::Size;
        (Term::Size::chars())[0] // ($ENV{COLUMNS} // 79);
    } || ($ENV{COLUMNS} // 79);

    # Use global $stats if loaded, otherwise load it
    my $stats_to_use = $stats // load_stats($config);

    # Calculate mtime range for normalization
    my ($newest_mtime, $oldest_mtime) = (0, time);
    for my $model (keys %$stats_to_use) {
        my $mtime = $stats_to_use->{$model}{mtime} // 0;
        $newest_mtime = $mtime if $mtime > $newest_mtime;
        $oldest_mtime = $mtime if $mtime < $oldest_mtime && $mtime > 0;
    }

    my @models = sort {
        rank_model($stats_to_use->{$a}, $newest_mtime, $oldest_mtime) <=>
        rank_model($stats_to_use->{$b}, $newest_mtime, $oldest_mtime)
    } keys %$stats_to_use;

    say "${whi}${inv} Models (lowest to highest rank) $rst\n";

    # Determine if we need to wrap based on longest model name + stats width
    my $longest_model = 0;
    for my $model (@models) {
        my $len = length($model);
        $longest_model = $len if $len > $longest_model;
    }

    # Stats columns: Rank(6) + SSD(5) + HDD(5) + Last(12) + Uses(6) + Mtime(12) + Tags(20) + spacing = ~75
    my $stats_width = 75;
    my $need_wrap = ($longest_model + $stats_width) > $term_width;
    my $wrapped_indent = ' ';

    my $tb;
    if ($need_wrap) {
        # Wrapped mode - no "Model" header, just indented stats columns
        $tb = Text::Table->new(
            $wrapped_indent,
            { title => "Rank", align => 'point', align_title => 'center'  },
            \"  ",
            { title => "SSD", align => 'left' },
            \"  ",
            { title => "HDD", align => 'left' },
            \"  ",
            { title => "Last", align => 'left' },
            \"  ",
            { title => "Uses", align => 'right', align_title => 'right' },
            \"  ",
            { title => "Mtime", align => 'left' },
            \"  ",
            { title => "Tags", align => 'left' },
        );
    } else {
        # Normal table with Model column
        $tb = Text::Table->new(
            { title => "Model", align => 'left' },
            \"  ",
            { title => "Rank", align => 'point', align_title => 'center'  },
            \"  ",
            { title => "ssd", align => 'left' },
            \"  ",
            { title => "hdd", align => 'left' },
            \"  ",
            { title => "Last", align => 'left' },
            \"  ",
            { title => "Uses", align => 'right', align_title => 'right' },
            \"  ",
            { title => "Mtime", align => 'left' },
            \"  ",
            { title => "Tags", align => 'left' },
        );
    }

    my @ssd_only_models;

    # Calculate available width for tags
    my $tags_col_width = 20;  # Default truncate width for tags

    for my $model (@models) {
        my $mstats = $stats_to_use->{$model};
        my $rank = sprintf("%.1f", rank_model($mstats, $newest_mtime, $oldest_mtime));
        my $uses = $mstats->{total_uses} // 0;
        my $last = $mstats->{last_used} ? substr($mstats->{last_used}, 0, 10) : 'never';

        # Format mtime
        my $mtime_str = 'unknown';
        if ($mstats->{mtime}) {
            my $mtime_obj = gmtime($mstats->{mtime});
            $mtime_str = $mtime_obj->strftime('%Y-%m-%d');
        }

        # Get locations from stats - trust what scan_models found
        my $locs = $mstats->{locations} // [];
        my $on_ssd = grep { $_ eq 'ssd' } @$locs;
        my $on_hdd = grep { $_ eq 'hdd' } @$locs;

        # Check if file still exists (for stats-only detection)
        my $stored_path = $mstats->{path};
        my $exists_on_disk = $stored_path && -f $stored_path;

        # Track SSD-only models (dangerous state)
        if ($on_ssd && !$on_hdd && $exists_on_disk) {
            push @ssd_only_models, $stored_path;
        }

        # Check if it should be cached
        my $should_cache = should_cache_to_ssd($mstats);

        # Build separate SSD and HDD display strings
        my $ssd_str = '';
        my $hdd_str = '';

        if (!$exists_on_disk) {
            # Model deleted from disk but stats remain
            $ssd_str = "${rst}${bro}st${rst}";
            $hdd_str = "${rst}${bro}st${rst}";
        } else {
            # SSD status
            if ($on_ssd && $should_cache) {
                $ssd_str = "${bcya}SSD${rst}";
            } elsif ($on_ssd && !$should_cache) {
                $ssd_str = "${bcya}ssd${rst}";
            } elsif (!$on_ssd && $should_cache) {
                $ssd_str = "${yel}{SSD}${rst}";
            }

            # HDD status
            if ($on_hdd) {
                $hdd_str = "${yel}HDD${rst}";
            }

            # Special case: only on SSD (dangerous)
            if ($on_ssd && !$on_hdd) {
                $hdd_str = "${red}***${rst}";
            }
        }

        # Format tags
        my $tags = $mstats->{tags} || [];
        my $tags_str = '';
        if (@$tags) {
            my $tags_display = join(' ', @$tags);
            if (length($tags_display) > $tags_col_width) {
                $tags_display = substr($tags_display, 0, $tags_col_width - 3) . '...';
            }
            $tags_str = "${c_tag}$tags_display$rst";
        }

        if ($need_wrap) {
            # Model name on its own line, then stats on next line with indent
            say "$cya$model$rst";
            $tb->add('', $rank, $ssd_str, $hdd_str, $last, $uses, "${rst}${cya}$mtime_str${rst}", $tags_str);
        } else {
            # Normal single-line display
            $tb->add("$cya$model$rst", $rank, $ssd_str, $hdd_str, $last, $uses, "${rst}${cya}$mtime_str${rst}", $tags_str);
        }
    }

    # Output the table
    if ($need_wrap) {
        # Print title first
        print $tb->title;

        # Get table body rows
        my @tb_rows = split /\n/, $tb->body;

        # Print each model name followed by its stats row
        for my $i (0 .. $#models) {
            say "$cya$models[$i]$rst";
            say $tb_rows[$i] if $i < @tb_rows;
        }

        # Print title at bottom
        print $tb->title;
    } else {
        # Normal mode - just print table
        print $tb;
        print $tb->title;
    }

    # Build and wrap key intelligently
    my @key_items = (
        "Key:",
        "SSD=cached+hot",
        "ssd=cached+cold",
        "{SSD}=should cache",
        "HDD=permanent",
        "${rst}${bro}st${rst}${gra}=stats only",
        "${red}***${rst}${gra}=SSD only!",
    );

    # Build key with intelligent wrapping
    my $key_line = "${gra}";
    my $current_len = 0;
    my $first_item = 1;

    for my $item (@key_items) {
        # Strip color codes to measure actual length
        my $item_plain = $item;
        $item_plain =~ s/\e\[[0-9;]+m//g;
        my $item_len = length($item_plain);

        my $separator = $first_item ? "" : ", ";
        my $sep_len = length($separator);

        if ($current_len > 0 && ($current_len + $sep_len + $item_len) > $term_width) {
            # Wrap to next line
            $key_line .= "\n${gra}     ";  # 5-space indent
            $current_len = 5;
            $separator = "";
        }

        $key_line .= $separator . $item;
        $current_len += $sep_len + $item_len;
        $first_item = 0;
    }

    say $key_line . $rst;

    # Warn about SSD-only models
    if (@ssd_only_models) {
        say "\n${red}${inv} WARNING $rst ${yel}@{[scalar @ssd_only_models]} model(s) only on SSD (not on HDD)$rst";
        say "${gra}These models won't be expired from SSD even if space is low.${rst}";
        say "${gra}Models on SSD missing from HDD:${rst}";
        for my $path (@ssd_only_models) {
            say "  ${red}$path${rst}";
        }
        say "";
    }
}

