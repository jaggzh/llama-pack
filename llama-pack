sub load_stats {
    my $config = shift;
    my $file = $config->{stats_file};

    return {} if !-f $file;

    open my $fh, '<', $file or return {};
    my $json = do { local $/; <$fh> };
    close $fh;
    return {} if $json !~ /\S/;

    return eval { decode_json($json) } // {};
}

sub atomic_json_write {
    my ($path, $data) = @_;

    my $dir = dirname($path);
    make_path($dir) unless -d $dir;

    my $tmp = "$path.tmp";
    my $lock = "$path.lock";

    open my $lfh, '>>', $lock or die "Can't open lock file $lock: $!";
    flock($lfh, LOCK_EX) or die "Can't lock $lock: $!";

    open my $fh, '>', $tmp or die "Can't write temp file $tmp: $!";
    print $fh JSON::XS->new->pretty->canonical->encode($data);
    close $fh or die "Can't close temp file $tmp: $!";

    rename $tmp, $path or die "Can't replace $path with $tmp: $!";
    close $lfh;
}

sub write_stats {
    my $config = load_config();

    eval {
        atomic_json_write($config->{stats_file}, $stats // {});
        1;
    } or do {
        serr(0, "Can't write stats: $@");
        return;
    };

    $stats_dirty = 0;
}

sub save_config {
    my $config = shift;

    open my $fh, '>', $config_file or die "Can't write config: $!";
    my $json_text = JSON::XS->new->pretty->canonical->encode($config);
    print $fh $json_text;
    close $fh;
}

sub metadata_cache_valid {
    my ($entry, $path, $cache_test) = @_;
    return 0 unless $entry && $entry->{gguf};
    return 0 unless $path && -f $path;

    my @tests = split /\s*,\s*/, ($cache_test // 'size');
    my @st = stat($path);
    return 0 unless @st;

    for my $test (@tests) {
        if ($test eq 'size') {
            return 0 unless defined $entry->{gguf}{source_size_bytes};
            return 0 unless $entry->{gguf}{source_size_bytes} == ($st[7] // -1);
        } elsif ($test eq 'time' || $test eq 'mtime') {
            return 0 unless defined $entry->{gguf}{source_mtime};
            return 0 unless $entry->{gguf}{source_mtime} == ($st[9] // -1);
        }
    }

    return 1;
}

sub kv_type_bytes {
    my $type = lc(shift // 'f16');
    return 4 if $type eq 'f32';
    return 2 if $type eq 'f16' || $type eq 'bf16';
    return 1 if $type eq 'q8_0';
    return 0.625 if $type eq 'q5_0' || $type eq 'q5_1';
    return 0.5625 if $type eq 'q4_1';
    return 0.5 if $type eq 'q4_0' || $type eq 'iq4_nl';
    return 2;
}

sub format_params_b {
    my $params_b = shift;
    return '' unless defined $params_b && $params_b > 0;
    return sprintf('%.2fB', $params_b) if $params_b < 10;
    return sprintf('%.1fB', $params_b) if $params_b < 100;
    return sprintf('%.0fB', $params_b);
}

sub effective_vram_gib {
    my ($config, $opts) = @_;
    return $opts->{vram} if $opts && defined $opts->{vram} && $opts->{vram} ne '';
    return $config->{planner_vram_gib} // 0;
}

sub estimate_max_context {
    my ($entry, $config, $opts) = @_;
    return undef unless $entry && $entry->{gguf};

    my $vram_gib = effective_vram_gib($config, $opts);
    return undef unless $vram_gib && $vram_gib > 0;

    my $kv_per_token = $entry->{gguf}{kv_bytes_per_token};
    return undef unless $kv_per_token && $kv_per_token > 0;

    my $margin = ($config->{planner_margin_mib} // 768) * 1024 * 1024;
    my $budget = ($vram_gib * 1024 * 1024 * 1024) - $margin;
    my $weights = $entry->{size_bytes} // $entry->{gguf}{source_size_bytes} // 0;
    my $remaining = $budget - $weights;
    return 0 if $remaining <= 0;

    return int($remaining / $kv_per_token);
}

sub probe_model_metadata {
    my ($config, $model_path) = @_;
    my $bin = $config->{bin_gguf_dump} // 'gguf_dump.py';

    open my $ph, '-|', $bin, '--verbose', $model_path
        or die "Can't run $bin on $model_path: $!";
    my @lines = <$ph>;
    close $ph or die "$bin failed for $model_path";

    my %kv;
    my $tensor_params = 0;

    for my $line (@lines) {
        chomp $line;
        if ($line =~ /^\s*\d+:\s+[^|]+\|\s*\d+\s*\|\s+([^=]+?)\s*=\s*(.+)\s*$/) {
            my ($key, $value) = ($1, $2);
            $key =~ s/^\s+|\s+$//g;
            $value =~ s/^\s+|\s+$//g;
            $value =~ s/^'(.*)'$/$1/;
            $kv{$key} = $value;
            if ($key =~ /^tokenizer\.ggml\.(tokens|token_type)$/ && $line =~ /\|\s*(\d+)\s*\|/) {
                $kv{$key . '.count'} = $2 + 0;
            }
            next;
        }

        if ($line =~ /^\s*\d+:\s+\d+\s*\|\s*([^|]+?)\|\s*[^|]+\|\s*.+$/) {
            my $dims = $1;
            my @dims = grep { $_ ne '' } map { s/^\s+|\s+$//gr } split /,/, $dims;
            my $n = 1;
            $n *= ($_ + 0) for @dims;
            $tensor_params += $n if $n > 0;
        }
    }

    my $arch = $kv{'general.architecture'} // '';
    my $ctx = $kv{"$arch.context_length"};
    my $layers = $kv{"$arch.block_count"};
    my $embed = $kv{"$arch.embedding_length"};
    my $heads = $kv{"$arch.attention.head_count"};
    my $heads_kv = $kv{"$arch.attention.head_count_kv"} // $heads;
    my $ffn = $kv{"$arch.feed_forward_length"};
    my $size_label = $kv{'general.size_label'};
    my $file_type = $kv{'general.file_type'};
    my $token_count = $kv{'tokenizer.ggml.tokens.count'} // $kv{'tokenizer.ggml.token_type.count'};

    my $head_dim_k = $kv{"$arch.attention.key_length"};
    my $head_dim_v = $kv{"$arch.attention.value_length"};
    if ((!defined $head_dim_k || $head_dim_k eq '') && $embed && $heads) {
        $head_dim_k = int($embed / $heads);
    }
    if ((!defined $head_dim_v || $head_dim_v eq '') && $embed && $heads) {
        $head_dim_v = int($embed / $heads);
    }

    my $n_embd_k_gqa = $kv{"$arch.attention.key_length_total"};
    my $n_embd_v_gqa = $kv{"$arch.attention.value_length_total"};
    if ((!defined $n_embd_k_gqa || $n_embd_k_gqa eq '') && $heads_kv && $head_dim_k) {
        $n_embd_k_gqa = $heads_kv * $head_dim_k;
    }
    if ((!defined $n_embd_v_gqa || $n_embd_v_gqa eq '') && $heads_kv && $head_dim_v) {
        $n_embd_v_gqa = $heads_kv * $head_dim_v;
    }

    my $kv_bytes_per_token;
    if ($layers && $n_embd_k_gqa && $n_embd_v_gqa) {
        my $ctk = kv_type_bytes($config->{planner_ctk});
        my $ctv = kv_type_bytes($config->{planner_ctv});
        $kv_bytes_per_token = $layers * (($n_embd_k_gqa * $ctk) + ($n_embd_v_gqa * $ctv));
    }

    my @st = stat($model_path);
    die "Can't stat $model_path: $!" unless @st;

    return {
        source_size_bytes => $st[7],
        source_mtime => $st[9],
        source_name => $kv{'general.name'},
        arch => $arch,
        size_label => $size_label,
        file_type => $file_type,
        quantization_version => $kv{'general.quantization_version'},
        params => $tensor_params,
        params_b => $tensor_params ? ($tensor_params / 1_000_000_000) : undef,
        train_ctx => $ctx,
        n_layer => $layers,
        n_embd => $embed,
        n_ff => $ffn,
        n_head => $heads,
        n_head_kv => $heads_kv,
        n_vocab => $token_count,
        n_embd_k_gqa => $n_embd_k_gqa,
        n_embd_v_gqa => $n_embd_v_gqa,
        kv_bytes_per_token => $kv_bytes_per_token,
        tokenizer_model => $kv{'tokenizer.ggml.model'},
        tokenizer_pre => $kv{'tokenizer.ggml.pre'},
        url => $kv{'general.url'} // $kv{'general.source.url'},
        dump_tool => $bin,
        dump_timestamp => gmtime->datetime,
    };
}

sub scan_models {
    my ($config, $opts) = @_;
    $opts //= {};

    # Load into global if not already loaded
    $stats //= load_stats($config);

    # Clear existing locations to rescan
    for my $key (keys %$stats) {
        $stats->{$key}{locations} = [];
    }

    for my $location (qw(ssd hdd)) {
        my $path = $config->{"${location}_path"};
        next unless -d $path;

        find(sub {
            return unless -f && /\.gguf$/i;
            # Skip mmproj files - they're not models
            return if /mmproj/i;
            my $full_path = $File::Find::name;
            say "$full_path" if $verbose;
            my $key = basename($full_path);

            $stats->{$key} //= {};
            $stats->{$key}{locations} //= [];

            # Only add if not already present
            push @{$stats->{$key}{locations}}, $location
                unless grep { $_ eq $location } @{$stats->{$key}{locations}};

            # Update path to prefer SSD
            if ($location eq 'ssd' || !$stats->{$key}{path}) {
                $stats->{$key}{path} = $full_path;
            }

            $stats->{$key}{size_bytes} = -s $full_path;
            $stats->{$key}{mtime} = (stat($full_path))[9];
        }, $path);
    }

    $stats_dirty = 1;
    write_stats();

    return unless $opts->{update_details};

    my @targets;
    if ($opts->{target_model}) {
        my $info = find_model($config, $stats, $opts->{target_model});
        die "Model '$opts->{target_model}' not found
" unless $info;
        @targets = ( basename($info->{path}) );
    } else {
        @targets = sort keys %$stats;
    }

    my $cache_test = $opts->{cache_test} // $config->{cache_test} // 'size';
    my $total = scalar @targets;
    my $done = 0;

    for my $key (@targets) {
        $done++;
        my $entry = $stats->{$key} // next;
        my $path = $entry->{path};
        unless ($path && -f $path) {
            say STDERR "[$done/$total] skipping $key (missing path)";
            next;
        }

        if (!$opts->{overwrite} && metadata_cache_valid($entry, $path, $cache_test)) {
            say STDERR "[$done/$total] cached $key" if $verbose;
            next;
        }

        say STDERR "[$done/$total] probing $key";
        my $meta = eval { probe_model_metadata($config, $path) };
        if (!$meta) {
            my $err = $@ || 'unknown error';
            chomp $err;
            say STDERR "  ${red}metadata probe failed${rst}: $err";
            next;
        }

        $entry->{gguf} = $meta;
        $stats_dirty = 1;
        write_stats();
    }
}

sub find_model {
    my ($config, $stats, $model_name) = @_;

    # Future: check nicknames here first
    # if (my $nick_model = lookup_nickname($stats, $model_name)) {
    #     return $nick_model;
    # }

    # Calculate mtime range for ranking
    my ($newest_mtime, $oldest_mtime) = (0, time);
    for my $model (keys %$stats) {
        my $mtime = $stats->{$model}{mtime} // 0;
        $newest_mtime = $mtime if $mtime > $newest_mtime;
        $oldest_mtime = $mtime if $mtime < $oldest_mtime && $mtime > 0;
    }

    # Try exact match first
    if ($stats->{$model_name}) {
        my $locs = $stats->{$model_name}{locations} // [];

        # Check actual filesystem for SSD presence (stats might be stale)
        my $ssd_path = $config->{ssd_path} . '/' . $model_name;
        my $has_ssd_file = -f $ssd_path;
        my $has_ssd_stat = grep { $_ eq 'ssd' } @$locs;

        # Update stats if we found SSD file that's not in stats
        if ($has_ssd_file && !$has_ssd_stat) {
            push @$locs, 'ssd';
            $stats->{$model_name}{locations} = $locs;
            $stats->{$model_name}{path} = $ssd_path;
            $stats_dirty = 1;
        }

        # Prefer SSD if available
        my $preferred = ($has_ssd_file || $has_ssd_stat) ? 'ssd' : ($locs->[0] // 'unknown');
        my $path = $has_ssd_file ? $ssd_path : $stats->{$model_name}{path};

        return {
            path => $path,
            location => $preferred,
            locations => $locs,
        };
    }

    # Try substring match
    my @matches;
    for my $key (keys %$stats) {
        push @matches, $key if $key =~ /\Q$model_name\E/i;
    }

    if (@matches == 0) {
        return undef;
    } elsif (@matches == 1) {
        my $key = $matches[0];
        my $locs = $stats->{$key}{locations} // [];

        # Check actual filesystem for SSD presence
        my $ssd_path = $config->{ssd_path} . '/' . $key;
        my $has_ssd_file = -f $ssd_path;
        my $has_ssd_stat = grep { $_ eq 'ssd' } @$locs;

        # Update stats if we found SSD file that's not in stats
        if ($has_ssd_file && !$has_ssd_stat) {
            push @$locs, 'ssd';
            $stats->{$key}{locations} = $locs;
            $stats->{$key}{path} = $ssd_path;
            $stats_dirty = 1;
        }

        my $preferred = ($has_ssd_file || $has_ssd_stat) ? 'ssd' : ($locs->[0] // 'unknown');
        my $path = $has_ssd_file ? $ssd_path : $stats->{$key}{path};

        return {
            path => $path,
            location => $preferred,
            locations => $locs,
        };
    } else {
        # Multiple matches - pick highest ranked
        say "${yel}Multiple models found matching '$model_name':$rst";
        my @ranked = sort {
            rank_model($stats->{$b}, $newest_mtime, $oldest_mtime) <=>
            rank_model($stats->{$a}, $newest_mtime, $oldest_mtime)
        } @matches;

        for my $m (@ranked) {
            my $rank = sprintf("%.1f", rank_model($stats->{$m}, $newest_mtime, $oldest_mtime));
            say "  $m (rank: $rank)";
        }

        my $chosen = $ranked[-1];  # Highest rank is at end now
        say "${gre}Using highest-ranked: $chosen$rst";

        my $locs = $stats->{$chosen}{locations} // [];

        # Check actual filesystem for SSD presence
        my $ssd_path = $config->{ssd_path} . '/' . $chosen;
        my $has_ssd_file = -f $ssd_path;
        my $has_ssd_stat = grep { $_ eq 'ssd' } @$locs;

        # Update stats if we found SSD file that's not in stats
        if ($has_ssd_file && !$has_ssd_stat) {
            push @$locs, 'ssd';
            $stats->{$chosen}{locations} = $locs;
            $stats->{$chosen}{path} = $ssd_path;
            $stats_dirty = 1;
        }

        my $preferred = ($has_ssd_file || $has_ssd_stat) ? 'ssd' : ($locs->[0] // 'unknown');
        my $path = $has_ssd_file ? $ssd_path : $stats->{$chosen}{path};

        return {
            path => $path,
            location => $preferred,
            locations => $locs,
        };
    }
}

sub rank_model {
    my ($mstats, $newest_mtime, $oldest_mtime) = @_;

    my $total_uses = $mstats->{total_uses} // 0;
    my $last_used = $mstats->{last_used};
    my $days_since = $last_used ? days_ago($last_used) : 999;

    # File mtime bonus: normalize file age to 0-1 range, scale to small bonus
    my $mtime_bonus = 0;
    if ($mstats->{mtime} && $newest_mtime && $oldest_mtime && $newest_mtime != $oldest_mtime) {
        # Newer files get higher bonus (0 to 0.5 points)
        my $normalized = ($mstats->{mtime} - $oldest_mtime) / ($newest_mtime - $oldest_mtime);
        $mtime_bonus = $normalized * 0.5;
    }

    # Simple ranking: recent use matters most, slight nudge for new files
    return $total_uses - ($days_since * 2) + $mtime_bonus;
}

sub days_ago {
    my $timestamp = shift;
    return 999 unless $timestamp;

    my $then = eval { Time::Piece->strptime($timestamp, '%Y-%m-%dT%H:%M:%S') };
    return 999 unless $then;

    my $diff = time - $then->epoch;
    return $diff / 86400;
}

sub should_cache_to_ssd {
    my $mstats = shift;
    my $timestamps = $mstats->{use_timestamps} // [];

    my $count = 0;
    for my $ts (@$timestamps) {
        $count++ if days_ago($ts) < 7;
    }

    return $count >= 2;
}

sub fork_ssd_copy {
    my ($config, $model_info, $stats) = @_;

    my $src = $model_info->{path};
    my $dst = $config->{ssd_path} . '/' . basename($src);

    # Check if already exists on SSD
    if (-f $dst) {
        say "${gre}Model already cached on SSD: $dst$rst" if $verbose;
        return;
    }

    my $pid = fork();
    if ($pid == 0) {
        # Child process
        say "${blu}[Background] Copying to SSD: $src -> $dst$rst" if $verbose;

        copy($src, $dst) or do {
            serr(0, "[Background] Copy failed: $!");
            exit 1;
        };

        say "${gre}[Background] Copy complete.$rst" if $verbose;
        exit 0;
    }
    # Parent: optimistically update stats to reflect future SSD presence
    my $model_key = basename($src);
    if ($stats->{$model_key}) {
        my $locs = $stats->{$model_key}{locations} // [];
        if (!grep { $_ eq 'ssd' } @$locs) {
            push @$locs, 'ssd';
            $stats->{$model_key}{locations} = $locs;
            $stats_dirty = 1;
        }
    }
}

sub start_server {
    my ($config, $opts, $model_info, $llama_args) = @_;

    my $binary = $config->{server_binary};
    my @cmd = ($binary, '-m', $model_info->{path}, @$llama_args);

    se "${gre}Starting: $rst" . join(' ', @cmd);

    # Write PID file BEFORE forking so we have the file reference
    my $pid_file = get_pid_file($config, $opts->{port});

    # Fork server
    my $pid = fork();
    die "Fork failed: $!" unless defined $pid;

    if ($pid == 0) {
        # Child - exec server
        exec(@cmd) or die "Exec failed: $!";
    }

    # Parent - write PID file with child's PID and wait
    $current_runtime_start = time;
    my $model_key = basename($model_info->{path});
    write_pid_file($config, $opts->{port}, $pid, $model_info->{path}, $llama_args);

    say "${gre}Server started (PID: $pid, Host:Port: $$opts{host}:$$opts{port})$rst";
    say "${gre}PID file: $pid_file$rst" if $verbose;

    # Wait for server - when it exits, update runtime stats
    waitpid($pid, 0);
    my $exit_status = $? >> 8;

    say "${yel}Server exited with status: $exit_status$rst" if $verbose;

    # Update runtime stats in global $stats
    my $runtime_seconds = time - $current_runtime_start;

    if ($stats->{$model_key}) {
        $stats->{$model_key}{total_runtime_seconds} //= 0;
        $stats->{$model_key}{total_runtime_seconds} += $runtime_seconds;
        $stats->{$model_key}{last_runtime_seconds} = $runtime_seconds;
        $stats_dirty = 1;

        say "${gre}Runtime logged: ${runtime_seconds}s$rst" if $verbose;
    }

    # Clean up PID file on exit
    unlink $pid_file if -f $pid_file;
}

sub get_pid_file {
    my ($config, $port) = @_;
    my $dir = $config->{pid_dir};
    make_path($dir) unless -d $dir;
    return "$dir/port-$port.pid";
}

sub write_pid_file {
    my ($config, $port, $pid, $model, $llama_args) = @_;

    my $file = get_pid_file($config, $port);
    my $args_hash = md5_hex(join('|', @$llama_args));

    open my $fh, '>', $file or die "Can't write PID file: $!";
    print $fh "$pid|$port|$model|$args_hash\n";
    close $fh;
}

sub read_pid_file {
    my $file = shift;

    open my $fh, '<', $file or return undef;
    my $line = <$fh>;
    close $fh;

    chomp $line;
    my ($pid, $port, $model, $args_hash) = split /\|/, $line;

    return {
        pid => $pid,
        port => $port,
        model => $model,
        args_hash => $args_hash,
    };
}

sub process_exists {
    my $pid = shift;
    return kill(0, $pid);
}

sub kill_pid {
    my $pid = shift;
    kill('TERM', $pid);
    sleep 1;
    kill('KILL', $pid) if process_exists($pid);
}

sub kill_instances {
    my ($config, $opts) = @_;

    my $pid_dir = $config->{pid_dir};
    unless (-d $pid_dir) {
        say "${yel}No PID directory found at: $pid_dir$rst";
        say "${gra}(No servers have been started yet)$rst";
        return;
    }

    opendir my $dh, $pid_dir or do {
        say "${red}Can't open PID directory: $!$rst";
        return;
    };
    my @pid_files = grep { /\.pid$/ } readdir($dh);
    closedir $dh;

    unless (@pid_files) {
        say "${yel}No running servers found.$rst";
        return;
    }

    say "${whi}Searching for servers to kill...$rst" if $verbose;

    my $killed_count = 0;
    for my $file (@pid_files) {
        # Skip if port specified and doesn't match (unless --killall)
        if ($opts->{port} && !$opts->{kill_all} && $file ne "port-$$opts{port}.pid") {
            say "${gra}Skipping $file (port mismatch)$rst" if $verbose >= 2;
            next;
        }

        my $full = "$pid_dir/$file";
        my $running = read_pid_file($full);

        unless ($running) {
            say "${gra}Removing malformed PID file: $file$rst" if $verbose >= 2;
            unlink $full;
            next;
        }

        if (process_exists($running->{pid})) {
            my $model_name = basename($running->{model});
            say "${yel}Killing: PID $$running{pid} on port $$running{port} ($model_name)$rst";
            kill_pid($running->{pid});
            unlink $full;
            $killed_count++;
        } else {
            say "${gra}Removing stale PID file: $file (process $$running{pid} not running)$rst" if $verbose;
            unlink $full;
        }

        last unless $opts->{kill_all};
    }

    if ($killed_count == 0) {
        say "${yel}No active servers found to kill.$rst";
    } else {
        say "${gre}Successfully killed $killed_count server(s).$rst";
    }
}

sub show_status {
    my $config = shift;
    my $pid_dir = $config->{pid_dir};

    unless (-d $pid_dir) {
        say "${yel}No PID directory found. No servers running.$rst";
        return;
    }

    opendir my $dh, $pid_dir or do {
        say "${red}Can't open PID directory: $!$rst";
        return;
    };
    my @pid_files = grep { /\.pid$/ } readdir($dh);
    closedir $dh;

    unless (@pid_files) {
        say "${yel}No running servers.$rst";
        return;
    }

    say "${whi}${inv} Running Servers $rst\n";

    my $tb = Text::Table->new(
        { title => "Port", align => 'right' },
        \"  ",
        { title => "PID", align => 'right' },
        \"  ",
        { title => "Model", align => 'left' },
        \"  ",
        { title => "Status", align => 'left' },
    );

    my $active_count = 0;
    for my $file (sort @pid_files) {
        my $full = "$pid_dir/$file";
        my $running = read_pid_file($full);

        unless ($running) {
            next;  # Skip malformed files
        }

        my $model_name = basename($running->{model});
        my $status;

        if (process_exists($running->{pid})) {
            $status = "${gre}RUNNING$rst";
            $active_count++;
        } else {
            $status = "${gra}STALE$rst";
        }

        $tb->add($running->{port}, $running->{pid}, "$cya$model_name$rst", $status);
    }

    print $tb;
    say "\n${gre}Active servers: $active_count$rst";
}

