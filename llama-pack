sub add_model_tag {
    my ($stats, $model_key, $tag, $known_tags) = @_;

    # Normalize tag
    $tag = uc($tag);
    $tag =~ s/^\s+|\s+$//g;

    # Validate tag name
    if ($tag =~ /[\s,]/) {
        say "${c_err}Invalid tag name '$tag' (no spaces or commas allowed)$rst";
        return;
    }

    # Check if known
    if (!exists $known_tags->{$tag}) {
        my @suggestions = suggest_similar_tags($tag, $known_tags);
        say "${c_warn}$tag is not a known tag.$rst";
        if (@suggestions) {
            say "  Did you mean: " . join(', ', map { "${c_attn}$_$rst" } @suggestions) . "?";
        }
        say "  Use ${c_attn}--gtag $tag:\"Description\"$rst to add $tag as a new tag first.";
        exit 1;
    }

    # Initialize tags array if needed
    $stats->{$model_key}{tags} ||= [];

    # Add if not already present
    my $tags = $stats->{$model_key}{tags};
    if (!grep { $_ eq $tag } @$tags) {
        push @$tags, $tag;
        @$tags = sort @$tags;  # Keep sorted
        $stats_dirty = 1;
        say "${c_attn}Added tag $tag to $model_key$rst" if $verbose;
    } else {
        say "${c_warn}Tag $tag already present on $model_key$rst" if $verbose;
    }
}

sub remove_model_tag {
    my ($stats, $model_key, $tag) = @_;

    # Normalize tag
    $tag = uc($tag);
    $tag =~ s/^\s+|\s+$//g;

    my $tags = $stats->{$model_key}{tags} || [];
    my $before_count = scalar @$tags;

    @$tags = grep { $_ ne $tag } @$tags;
    $stats->{$model_key}{tags} = $tags;

    if (scalar @$tags < $before_count) {
        $stats_dirty = 1;
        say "${c_attn}Removed tag $tag from $model_key$rst" if $verbose;
    } else {
        say "${c_warn}Tag $tag was not present on $model_key$rst" if $verbose;
    }
}

sub manage_global_tag {
    my ($config, $op) = @_;

    if ($op =~ /^-(.+)$/) {
        # Remove tag
        my $tag = uc($1);
        if (exists $config->{known_tags}{$tag}) {
            delete $config->{known_tags}{$tag};
            save_config($config);
            say "${c_attn}Removed $tag from global tag registry$rst";
        } else {
            say "${c_warn}Tag $tag not in registry$rst";
        }
    } elsif ($op =~ /^([^:]+):(.+)$/) {
        # Add/update tag with description
        my ($tag, $desc) = (uc($1), $2);
        $tag =~ s/^\s+|\s+$//g;
        $desc =~ s/^\s+|\s+$//g;

        if ($tag =~ /[\s,]/) {
            say "${c_err}Invalid tag name '$tag' (no spaces or commas allowed)$rst";
            return;
        }

        $config->{known_tags}{$tag} = $desc;
        save_config($config);
        say "${c_attn}Added/updated tag $tag: $desc$rst";
    } else {
        say "${c_err}Invalid --gtag format. Use: TAG:DESCRIPTION or -TAG$rst";
        exit 1;
    }
}

sub rename_global_tag {
    my ($config, $stats, $rename_spec) = @_;

    unless ($rename_spec =~ /^([^:]+):([^:]+)$/) {
        say "${c_err}Invalid rename format. Use: OLD:NEW$rst";
        exit 1;
    }

    my ($old_tag, $new_tag) = (uc($1), uc($2));
    $old_tag =~ s/^\s+|\s+$//g;
    $new_tag =~ s/^\s+|\s+$//g;

    if (!exists $config->{known_tags}{$old_tag}) {
        say "${c_err}Tag $old_tag not found in registry$rst";
        exit 1;
    }

    # Update registry
    $config->{known_tags}{$new_tag} = $config->{known_tags}{$old_tag};
    delete $config->{known_tags}{$old_tag};
    save_config($config);

    # Update all models
    my $count = 0;
    for my $model_key (keys %$stats) {
        my $tags = $stats->{$model_key}{tags} || [];
        for my $i (0 .. $#$tags) {
            if ($tags->[$i] eq $old_tag) {
                $tags->[$i] = $new_tag;
                $count++;
            }
        }
        @$tags = sort @$tags if @$tags;
    }

    $stats_dirty = 1 if $count > 0;
    say "${c_attn}Renamed $old_tag → $new_tag across $count model(s)$rst";
}

sub update_tag_description {
    my ($config, $desc_spec) = @_;

    unless ($desc_spec =~ /^([^:]+):(.+)$/) {
        say "${c_err}Invalid format. Use: TAG:DESCRIPTION$rst";
        exit 1;
    }

    my ($tag, $desc) = (uc($1), $2);
    $tag =~ s/^\s+|\s+$//g;
    $desc =~ s/^\s+|\s+$//g;

    if (!exists $config->{known_tags}{$tag}) {
        say "${c_err}Tag $tag not found in registry$rst";
        exit 1;
    }

    $config->{known_tags}{$tag} = $desc;
    save_config($config);
    say "${c_attn}Updated description for $tag: $desc$rst";
}

sub list_known_tags {
    my $config = shift;

    my $known_tags = get_known_tags($config);

    unless (keys %$known_tags) {
        say "${c_warn}No tags in global registry$rst";
        return;
    }

    say "${whi}${inv} Known Tags $rst\n";

    my $tb = Text::Table->new(
        { title => "Tag", align => 'left' },
        \"  ",
        { title => "Description", align => 'left' },
    );

    for my $tag (sort keys %$known_tags) {
        $tb->add("${c_tag}$tag$rst", $known_tags->{$tag});
    }

    print $tb;
}

sub suggest_similar_tags {
    my ($tag, $known_tags) = @_;

    my @suggestions;
    for my $known (keys %$known_tags) {
        my $dist = levenshtein($tag, $known);
        push @suggestions, { tag => $known, dist => $dist } if $dist <= 2;
    }

    @suggestions = sort { $a->{dist} <=> $b->{dist} } @suggestions;
    return map { $_->{tag} } @suggestions;
}

sub levenshtein {
    my ($s1, $s2) = @_;
    my @s1 = split //, $s1;
    my @s2 = split //, $s2;

    my @d;
    $d[$_][0] = $_ for (0 .. @s1);
    $d[0][$_] = $_ for (0 .. @s2);

    for my $i (1 .. @s1) {
        for my $j (1 .. @s2) {
            $d[$i][$j] = $s1[$i-1] eq $s2[$j-1] ? $d[$i-1][$j-1] :
                         1 + (
                             $d[$i-1][$j] < $d[$i][$j-1] ?
                             ($d[$i-1][$j] < $d[$i-1][$j-1] ? $d[$i-1][$j] : $d[$i-1][$j-1]) :
                             ($d[$i][$j-1] < $d[$i-1][$j-1] ? $d[$i][$j-1] : $d[$i-1][$j-1])
                         );
        }
    }

    return $d[@s1][@s2];
}

sub edit_model_note {
    my ($stats, $model_key, $editor) = @_;

    my $note = $stats->{$model_key}{note} || '';

    # Create temp file
    my $tmpfname = "/tmp/llama-pack-note-$$.tmp";

    my $omask = umask 0177;
    write_text($tmpfname, $note);
    umask $omask;

    # Edit
    system($editor, $tmpfname);

    # Read back
    my $newnote = read_text($tmpfname);
    $newnote =~ s/(\A\s+)|(\s+\z)//sg;
    $note =~ s/(\A\s+)|(\s+\z)//sg;

    unlink $tmpfname;

    if ($newnote eq $note) {
        say "${c_warn}No changes made$rst";
    } elsif ($newnote =~ /\A\s*\z/s) {
        delete $stats->{$model_key}{note};
        $stats_dirty = 1;
        say "${c_attn}Note deleted$rst";
    } else {
        $stats->{$model_key}{note} = $newnote;
        $stats_dirty = 1;
        say "${c_attn}Note updated$rst";
    }
}

sub set_model_note {
    my ($stats, $model_key, $note_str) = @_;

    $note_str =~ s/(\A\s+)|(\s+\z)//sg;

