}

sub rename_model_entry {
    my ($config, $stats, $spec) = @_;

    my ($old, $new) = split /,/, ($spec // ''), 2;
    for ($old, $new) {
        $_ //= '';
        s/^\s+|\s+$//g;
    }

    die "Use --rename old.gguf,new.gguf
" unless $old && $new;
    die "New name must end with .gguf
" unless $new =~ /\.gguf\z/i;

    my $model_info = find_model($config, $stats, $old)
        or die "Model '$old' not found
";

    my $old_key = basename($model_info->{path});
    die "Target '$new' already exists in stats
" if exists $stats->{$new};

    my @moved;
    for my $location (@{$model_info->{locations} // []}) {
        my $base = $config->{"${location}_path"};
        next unless $base && -d $base;

        my $src = "$base/$old_key";
        next unless -f $src;

        my $dst = "$base/$new";
        die "Target file already exists: $dst
" if -e $dst;
        rename $src, $dst or die "Rename failed: $src -> $dst: $!
";
        push @moved, [$location, $dst];
    }

    my $entry = delete $stats->{$old_key} // {};
    $stats->{$new} = $entry;
    $stats->{$new}{locations} = [ map { $_->[0] } @moved ] if @moved;

    my ($ssd_dst) = map { $_->[1] } grep { $_->[0] eq 'ssd' } @moved;
    my ($hdd_dst) = map { $_->[1] } grep { $_->[0] eq 'hdd' } @moved;
    $stats->{$new}{path} = $ssd_dst // $hdd_dst // $stats->{$new}{path};
    $stats->{$new}{size_bytes} = -s $stats->{$new}{path} if $stats->{$new}{path} && -f $stats->{$new}{path};
    $stats->{$new}{mtime} = (stat($stats->{$new}{path}))[9] if $stats->{$new}{path} && -f $stats->{$new}{path};
    if ($stats->{$new}{gguf}) {
        $stats->{$new}{gguf}{source_size_bytes} = $stats->{$new}{size_bytes} if $stats->{$new}{size_bytes};
        $stats->{$new}{gguf}{source_mtime} = $stats->{$new}{mtime} if $stats->{$new}{mtime};
    }

    $stats_dirty = 1;
    write_stats();

    say "${gre}Renamed:${rst} $old_key -> $new";
}

